rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Usuários: só o próprio usuário ou gestor lê/escreve
    match /usuarios/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Coleções principais: apenas autenticados
    match /orcamentos/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /projetos/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /calculos/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /arquitetura/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /art/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Coleções de Configuração: apenas gestores podem ler/escrever
    match /campos_dinamicos/{doc} {
      allow read: if request.auth != null && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.perfil == 'gestor';
      allow write: if request.auth != null && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.perfil == 'gestor';
    }
    match /regras_condicionais/{doc} {
      allow read: if request.auth != null && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.perfil == 'gestor';
      allow write: if request.auth != null && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.perfil == 'gestor';
    }
    match /permissoes_campos/{doc} {
      allow read: if request.auth != null && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.perfil == 'gestor';
      allow write: if request.auth != null && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.perfil == 'gestor';
    }
    match /kpis_customizados/{doc} {
      allow read: if request.auth != null && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.perfil == 'gestor';
      allow write: if request.auth != null && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.perfil == 'gestor';
    }
    match /mensagens_globais/{doc} {
      allow read: if request.auth != null && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.perfil == 'gestor';
      allow write: if request.auth != null && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.perfil == 'gestor';
    }
    match /automacoes/{doc} {
      allow read: if request.auth != null && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.perfil == 'gestor';
      allow write: if request.auth != null && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.perfil == 'gestor';
    }
    match /auditoria_configuracoes/{doc} {
      allow read: if request.auth != null && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.perfil == 'gestor';
      allow write: if request.auth != null && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.perfil == 'gestor';
    }
    match /configuracoes/{doc} {
      allow read: if request.auth != null && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.perfil == 'gestor';
      allow write: if request.auth != null && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.perfil == 'gestor';
    }
  }
}
